	"item": [
		{
			"name": "AUTH - Autenticación",
			"item": [
				{
					"name": "1. Login (Obtener Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.token) {",
									"        pm.collectionVariables.set('jwtToken', jsonData.token);",
									"        console.log('Token guardado exitosamente');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"JLEMA001\",\n    \"password\": \"1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrlClientes}}/api/v1/auth/login",
							"host": ["{{baseUrlClientes}}"],
							"path": ["api", "v1", "auth", "login"]
						},
						"description": "Paso 1: Iniciar sesión para obtener el token JWT. Este endpoint guarda automáticamente el token en la variable {{jwtToken}}."
					},
					"response": []
				},
				{
					"name": "2. Register (Crear cliente + Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.datos && jsonData.datos.token) {",
									"        pm.collectionVariables.set('jwtToken', jsonData.datos.token);",
									"        console.log('Token de registro guardado');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"TEST001\",\n    \"password\": \"test123\"\n}"
						},
						"url": {
							"raw": "{{baseUrlClientes}}/api/v1/auth/register",
							"host": ["{{baseUrlClientes}}"],
							"path": ["api", "v1", "auth", "register"]
						},
						"description": "Registrar un nuevo cliente y obtener token JWT"
					},
					"response": []
				}
			]
		},
